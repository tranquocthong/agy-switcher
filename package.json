{
  "name": "agyw",
  "version": "0.1.4",
  "description": "Agency Profile Switcher for agy (Google Antigravity CLI)",
  "type": "module",
  "bin": {
    "agyw": "dist/cli/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "agy",
    "antigravity",
    "profile",
    "switcher",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tranquocthong/agy-switcher.git"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^4.4.1",
    "js-yaml": "^4.2.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^3.2.6",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
